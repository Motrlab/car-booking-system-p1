generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id           Int      @id @default(autoincrement())
  customerName String
  phone        String
  carType      String
  service      String
  bookingDate  DateTime
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}

model Leads {
  id        String   @id @default(uuid())
  name      String
  phone     String
  createdAt DateTime @default(now())
}

model Worker {
  id              String    @id @default(uuid())
  fullName        String
  iqamaNumber     String    @unique
  passportNumber  String?   @unique
  iqamaExpiryDate DateTime?
  salary          Float?
  technicianType  String
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vehicleJobs VehicleJob[]
}

model VehicleJob {
  id             String    @id @default(uuid())
  customerName   String
  phone          String
  carBrand       String
  carType        String
  plateNumber    String
  carColor       String?
  carYear        String?
  odometer       String?
  vinLast6       String?
  serviceDetails String
  cost           Float
  workerId       String?
  expectedExitAt DateTime?
  actualExitAt   DateTime?
  status         String    @default("received")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  worker  Worker?        @relation(fields: [workerId], references: [id])
  images  VehicleImage[]
  invoice Invoice?

  @@index([workerId])
}

model VehicleImage {
  id        String   @id @default(uuid())
  jobId     String
  fileName  String
  mimeType  String
  category  String   @default("general")
  data      Bytes
  createdAt DateTime @default(now())

  job VehicleJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model InvoiceSequence {
  id         Int @id @default(autoincrement())
  year       Int
  month      Int
  lastNumber Int

  @@unique([year, month])
}

model Invoice {
  id    String @id @default(uuid())
  jobId String @unique

  invoiceNumber            String?
  invoiceSequence          Int?    @unique
  invoiceSequenceFormatted String? @unique

  customerName  String?
  customerPhone String?

  carBrand    String?
  carType     String?
  plateNumber String?
  vinLast6    String?

  serviceDetails String?

  subtotal  Float?
  vatAmount Float?
  total     Float?

  qrCode    String?
  status    String    @default("issued")
  issuedAt  DateTime?
  createdAt DateTime  @default(now())

  job VehicleJob @relation(fields: [jobId], references: [id], onDelete: Restrict)

  @@index([jobId])
}
